#!/usr/bin/env bash
#===============================================================================
# qsubsh2.sh
# Compatible job submitter for PBS Pro, Torque, SGE and Slurm
#
# Improvements over qsubshcom while keeping the same calling style:
# - shell-style parsing for other_params, then pass submit params as arrays
# - explicit submit failure handling
# - safer temp file cleanup via trap
# - better array task handling, including Torque TASK_ID fallback
# - monitor uses CPU seconds instead of summing formatted cputime strings
#===============================================================================

set -o pipefail

usage() {
    cat <<'EOF'
usage:
  qsubsh2.sh "command1 |; command2" num_cpu memory task_name wait_time other_params

notes:
  - command supports {TASK_ID} placeholder for array jobs
  - other_params is parsed using shell-style quoting, so quoted values are preserved
  - reserved meta params:
      -ge=TOR|SGE|PBS|SLM
      -wait=JOB1:JOB2:JOB3
      -array=1-100:2
      -log=log_name
      -ntype=node_type
      -acct=account_name
      -queue=queue_name
  - all other params are forwarded to qsub/sbatch
EOF
}

die() {
    echo "Error: $*" >&2
    exit 1
}

warn() {
    echo "Warning: $*" >&2
}

cleanup() {
    if [[ -n "${scriptname:-}" && -f "${scriptname:-}" ]]; then
        rm -f "$scriptname"
    fi
}

parse_shell_words() {
    local input="$1"
    PARSED_WORDS=()

    if [[ -z "${input//[[:space:]]/}" ]]; then
        return 0
    fi

    set -f
    eval "PARSED_WORDS=($input)"
    local status=$?
    set +f
    return "$status"
}

detect_grid_engine() {
    local forced_ge="${1:-}"
    local ge=""

    if [[ -n "$forced_ge" ]]; then
        ge="${forced_ge^^}"
        [[ "$ge" =~ ^(TOR|SGE|PBS|SLM)$ ]] || die "Unsupported -ge value: $forced_ge"
        printf '%s\n' "$ge"
        return 0
    fi

    if command -v qsh >/dev/null 2>&1; then
        printf 'SGE\n'
        return 0
    fi

    if command -v qsub >/dev/null 2>&1; then
        if command -v qchkpt >/dev/null 2>&1; then
            printf 'TOR\n'
        else
            printf 'PBS\n'
        fi
        return 0
    fi

    if command -v sbatch >/dev/null 2>&1; then
        printf 'SLM\n'
        return 0
    fi

    return 1
}

job_exists() {
    local ge="$1"
    local job="$2"

    case "$ge" in
        PBS|TOR)
            qstat -f "$job" >/dev/null 2>&1
            ;;
        SGE)
            qstat -j "$job" >/dev/null 2>&1
            ;;
        SLM)
            squeue -h -j "$job" 2>/dev/null | grep -q .
            ;;
        *)
            return 1
            ;;
    esac
}

parse_job_id() {
    local ge="$1"
    local output="$2"

    case "$ge" in
        SGE)
            sed -nE 's/Your (job|job-array) ([0-9]+).*/\2/p' <<< "$output" | head -n 1
            ;;
        PBS)
            awk 'NF { print; exit }' <<< "$output"
            ;;
        TOR)
            awk 'NF { last=$0 } END { print last }' <<< "$output"
            ;;
        SLM)
            sed -nE 's/.* ([0-9]+).*/\1/p' <<< "$output" | head -n 1
            ;;
    esac
}

submit_torque_array_bridge() {
    local array_job="$1"
    local self_path="$2"
    shift 2
    local remain_bridge_params=("$@")
    local bridge_extra="-W depend=afterokarray:${array_job}"
    local remain_encoded=""
    local bridge_output=""
    local bridge_job_id=""

    if (( ${#remain_bridge_params[@]} > 0 )); then
        printf -v remain_encoded '%q ' "${remain_bridge_params[@]}"
        remain_encoded="${remain_encoded% }"
        bridge_extra="${bridge_extra} ${remain_encoded}"
    fi

    if ! bridge_output=$(
        "$self_path" \
            "echo torque-array-wait-bridge" \
            1 \
            10MB \
            qwait_ar \
            00:00:30 \
            "$bridge_extra" 2>&1
    ); then
        warn "Failed to create Torque array wait bridge for $array_job"
        warn "$bridge_output"
        return 1
    fi

    bridge_job_id="$(awk 'NF { last=$0 } END { print last }' <<< "$bridge_output")"
    [[ -n "$bridge_job_id" ]] || return 1
    printf '%s\n' "$bridge_job_id"
}

if [[ $# -ne 6 ]]; then
    usage >&2
    die "Expected 6 arguments, got $#"
fi

command_string="$1"
cpu="$2"
memory_raw="$3"
job_name="$4"
walltime="$5"
raw_other_params="$6"
self_path="${BASH_SOURCE[0]:-$0}"

[[ "$cpu" =~ ^[1-9][0-9]*$ ]] || die "num_cpu must be a positive integer"
[[ -n "$job_name" ]] || die "task_name cannot be empty"

mkdir -p ./job_reports || die "Cannot create ./job_reports"
today="$(date +%Y.%m.%d_%H.%M.%S)"
today_log="$(date +%Y.%m.%d)"

raw_additions="$raw_other_params"
if [[ -n "${QSUBSHCOM_EXTRAS:-}" ]]; then
    raw_additions="${raw_additions} ${QSUBSHCOM_EXTRAS}"
fi

if ! parse_shell_words "$raw_additions"; then
    die "Unable to parse other_params. Check quotes and escaping."
fi

force_ge=""
wait_jobs=""
array_spec=""
log_stem=""
node_type=""
queue=""
account=""
remaining_submit_params=()

for token in "${PARSED_WORDS[@]}"; do
    case "$token" in
        -ge=*)
            force_ge="${token#-ge=}"
            ;;
        -wait=*)
            wait_jobs="${token#-wait=}"
            ;;
        -array=*)
            array_spec="${token#-array=}"
            ;;
        -log=*)
            log_stem="${token#-log=}"
            ;;
        -ntype=*)
            node_type="${token#-ntype=}"
            ;;
        -queue=*)
            queue="${token#-queue=}"
            ;;
        -acct=*)
            account="${token#-acct=}"
            ;;
        *)
            remaining_submit_params+=("$token")
            ;;
    esac
done

GE="$(detect_grid_engine "$force_ge")" || die "Cannot recognize the grid engine. Use -ge=TOR|SGE|PBS|SLM."

mem_value="${memory_raw//[![:digit:]]/}"
mem_unit="${memory_raw//[[:digit:]]/}"
[[ -n "$mem_value" ]] || die "memory must start with a number, e.g. 2G"
[[ -n "$mem_unit" ]] || die "memory must include a unit, e.g. 2G or 500M"

if [[ "$GE" == "TOR" || "$GE" == "SLM" ]]; then
    mem_unit="${mem_unit^^}"
    if [[ "${mem_unit: -1}" != "B" ]]; then
        mem_unit="${mem_unit}B"
    fi
fi

mem_core=$(( (mem_value + cpu - 1) / cpu ))
is_array=0
if [[ -n "$array_spec" ]]; then
    is_array=1
fi

scriptname="$(mktemp "${TMPDIR:-/tmp}/qsubsh2.XXXXXX")" || die "mktemp failed"
trap cleanup EXIT

{
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -o pipefail'

    if [[ "$GE" == "SGE" ]]; then
        printf '%s\n' "#$ -N ${job_name}"
        printf '%s\n' '#$ -S /bin/bash'
        printf '%s\n' '#$ -j y'
        printf '%s\n' '#$ -o ./job_reports/'
        printf '%s\n' '#$ -cwd'
        printf '%s\n' '#$ -V'
        printf '%s\n' "#$ -pe thread ${cpu}"
        printf '%s\n' "#$ -l h_vmem=${mem_core}${mem_unit}"
        if [[ -n "$queue" ]]; then
            printf '%s\n' "#$ -q ${queue}"
        fi
        if [[ -n "$account" ]]; then
            printf '%s\n' "#$ -A ${account}"
        fi
    fi

    if [[ "$GE" == "PBS" || "$GE" == "TOR" ]]; then
        local_ntype=""
        if [[ -n "$node_type" ]]; then
            local_ntype=":NodeType=${node_type}"
        fi
        printf '%s\n' "#PBS -N ${job_name}"
        printf '%s\n' '#PBS -S /bin/bash'
        printf '%s\n' '#PBS -V'
        printf '%s\n' "#PBS -l select=1:ncpus=${cpu}${local_ntype}:mem=${mem_value}${mem_unit}"
        if [[ -n "$walltime" ]]; then
            printf '%s\n' "#PBS -l walltime=${walltime}"
        fi
        if [[ -n "$queue" ]]; then
            printf '%s\n' "#PBS -q ${queue}"
        fi
        if [[ -n "$account" ]]; then
            printf '%s\n' "#PBS -A ${account}"
        fi
    fi

    if [[ "$GE" == "SLM" ]]; then
        printf '%s\n' "#SBATCH --job-name=${job_name}"
        printf '%s\n' '#SBATCH --ntasks=1'
        printf '%s\n' "#SBATCH --cpus-per-task=${cpu}"
        printf '%s\n' "#SBATCH --mem=${mem_value}${mem_unit}"
        if [[ -n "$walltime" ]]; then
            printf '%s\n' "#SBATCH --time=${walltime}"
        fi
        if [[ -n "$queue" ]]; then
            printf '%s\n' "#SBATCH --partition=${queue}"
        fi
        if [[ -n "$account" ]]; then
            printf '%s\n' "#SBATCH -A ${account}"
        fi
    fi

    if [[ "$GE" == "PBS" ]]; then
        if (( is_array == 1 )); then
            printf '%s\n' "#PBS -o ./job_reports/${job_name}_${today}_A^array_index^.log"
            printf '%s\n' "#PBS -e ./job_reports/${job_name}_${today}_A^array_index^.err"
        else
            printf '%s\n' "#PBS -o ./job_reports/${job_name}_${today}.log"
            printf '%s\n' "#PBS -e ./job_reports/${job_name}_${today}.err"
        fi
    fi

    if [[ "$GE" == "TOR" ]]; then
        if (( is_array == 1 )); then
            printf '%s\n' "#PBS -o ./job_reports/${job_name}_${today}.submit.log"
            printf '%s\n' "#PBS -e ./job_reports/${job_name}_${today}.submit.err"
        else
            printf '%s\n' "#PBS -o ./job_reports/${job_name}_${today}.log"
            printf '%s\n' "#PBS -e ./job_reports/${job_name}_${today}.err"
        fi
    fi

    if [[ "$GE" == "SLM" ]]; then
        if (( is_array == 1 )); then
            printf '%s\n' "#SBATCH -o ./job_reports/${job_name}_${today}_A%a.log"
            printf '%s\n' "#SBATCH -e ./job_reports/${job_name}_${today}_A%a.err"
        else
            printf '%s\n' "#SBATCH -o ./job_reports/${job_name}_${today}.log"
            printf '%s\n' "#SBATCH -e ./job_reports/${job_name}_${today}.err"
        fi
    fi

    if [[ "$GE" == "PBS" || "$GE" == "TOR" ]]; then
        printf '%s\n' 'cd "${PBS_O_WORKDIR:-$PWD}"'
        printf '%s\n' 'export JOB_ID="${PBS_JOBID:-}"'
        printf '%s\n' 'export TASK_ID="${PBS_ARRAY_INDEX:-${PBS_ARRAYID:-0}}"'
    elif [[ "$GE" == "SGE" ]]; then
        printf '%s\n' 'export JOB_ID="${JOB_ID:-}"'
        printf '%s\n' 'export TASK_ID="${SGE_TASK_ID:-0}"'
    elif [[ "$GE" == "SLM" ]]; then
        printf '%s\n' 'export JOB_ID="${SLURM_JOB_ID:-}"'
        printf '%s\n' 'export TASK_ID="${SLURM_ARRAY_TASK_ID:-0}"'
    fi

    if [[ "$GE" == "TOR" && "$is_array" -eq 1 ]]; then
        printf '%s\n' "exec > \"./job_reports/${job_name}_${today}_A\${TASK_ID}.log\" 2> \"./job_reports/${job_name}_${today}_A\${TASK_ID}.err\""
    fi

    printf '%s\n' 'echo "Job ID: ${JOB_ID:-}"'
    printf '%s\n' 'echo "Array ID: ${TASK_ID:-}"'
    printf '%s\n' "cat <<'EOF'"
    printf '%s\n' "PARAM to here: $*"
    printf '%s\n' 'EOF'
    printf '%s\n' 'echo ""'
    printf '%s\n' 'echo ========QSUB STD out========'

    if (( is_array == 1 )); then
        printf '%s\n' "mlog=\"./job_reports/${job_name}_${today}_A\${TASK_ID}.mon\""
    else
        printf '%s\n' "mlog=\"./job_reports/${job_name}_${today}.mon\""
    fi
    printf '%s\n' 'tMon=10'

    cat <<'EOF'
collect_child_pids() {
    local parent_pid="$1"
    local child_pid=""

    while IFS= read -r child_pid; do
        [[ -n "$child_pid" ]] || continue
        echo "$child_pid"
        collect_child_pids "$child_pid"
    done < <(pgrep -P "$parent_pid" 2>/dev/null || true)
}

sum_res_pids() {
    local root_pid="$1"
    local temp_file=""
    local child_pid=""
    local pid=""
    local stats=""
    local vmhwm=""
    local etime=""
    local result=""
    local pids=("$root_pid")

    temp_file="$(mktemp)"

    while IFS= read -r child_pid; do
        [[ -n "$child_pid" ]] && pids+=("$child_pid")
    done < <(collect_child_pids "$root_pid")

    etime="$(ps --no-headers -o etimes= -p "$root_pid" 2>/dev/null | awk 'NR==1 { print $1 + 0 }')"

    for pid in "${pids[@]}"; do
        stats="$(ps --no-headers -o cputimes=,pcpu=,rss=,vsz= -p "$pid" 2>/dev/null | awk 'NF { print $1, $2, $3, $4 }')"
        [[ -n "$stats" ]] || continue

        if [[ -r "/proc/$pid/status" ]]; then
            vmhwm="$(awk '/VmHWM:/ { print $2; exit }' "/proc/$pid/status")"
        else
            vmhwm=0
        fi

        printf '%s %s\n' "$stats" "${vmhwm:-0}" >> "$temp_file"
    done

    if [[ -s "$temp_file" ]]; then
        result="$(
            awk '
                {
                    sum_cpu += $1
                    sum_pcpu += $2
                    sum_rss += $3
                    sum_vsz += $4
                    sum_vmhwm += $5
                }
                END {
                    printf "%d\t%.2f\t%d\t%d\t%d", sum_cpu, sum_pcpu, sum_rss, sum_vsz, sum_vmhwm
                }
            ' "$temp_file"
        )"
    else
        result=$'0\t0.00\t0\t0\t0'
    fi

    rm -f "$temp_file"
    printf '%s\t%s\n' "${etime:-0}" "$result"
}

monitor() {
    local interval="$1"
    local logfile="$2"
    local monitor_pid="$BASHPID"
    local shell_pid="$$"
    local parent_pid="$PPID"
    local count_child=0
    local run_pids=()
    local pid=""
    local comm=""
    local time_now=""

    echo "Task start: $(date +%T)" > "$logfile"
    echo "\$BASHPID: $monitor_pid" >> "$logfile"
    echo "\$\$: $shell_pid" >> "$logfile"
    echo "\$PPID: $parent_pid" >> "$logfile"
    echo "" >> "$logfile"
    echo -e "Time\tELAPSED\tCPU_SECONDS\t%CPU\tRSS\tVSZ\tVmHWM" >> "$logfile"

    while true; do
        time_now="$(date +%T)"
        count_child=0

        while read -r pid comm; do
            [[ -n "$pid" ]] && ((count_child++))
        done < <(ps --no-headers -o pid=,comm= --ppid "$parent_pid" 2>/dev/null)

        if (( count_child == 0 )); then
            echo "" >> "$logfile"
            echo "Task finished: $(date +%T)" >> "$logfile"
            break
        fi

        run_pids=()
        while read -r pid comm; do
            [[ -n "$pid" && "$pid" != "$monitor_pid" ]] && run_pids+=("$pid")
        done < <(ps --no-headers -o pid=,comm= --ppid "$shell_pid" 2>/dev/null)

        if (( ${#run_pids[@]} == 1 )); then
            printf '%s\t%s\n' "$time_now" "$(sum_res_pids "${run_pids[0]}")" >> "$logfile"
        elif (( ${#run_pids[@]} == 0 )); then
            echo "$time_now: No job" >> "$logfile"
        else
            echo "$time_now: multiple job" >> "$logfile"
            ps --no-headers -o pid=,comm= --ppid "$shell_pid" >> "$logfile"
        fi

        sleep "$interval"
    done
}

monitor "$tMon" "$mlog" &
EOF

    printf '%s\n' "export OMP_NUM_THREADS=${cpu}"
    printf '%s\n' "export OPENBLAS_NUM_THREADS=${cpu}"
    printf '%s\n' "export MKL_NUM_THREADS=${cpu}"
    printf '%s\n' "export NUMEXPR_NUM_THREADS=${cpu}"
    sed 's/\$\?{TASK_ID}/${TASK_ID}/g; s/[[:space:]]*|;[[:space:]]*/\
/g' <<< "$command_string"
    printf '%s\n' 'echo =========QSUB STD end========='
    printf '%s\n' 'echo ""'
} > "$scriptname"

submit_cmd=(qsub)
if [[ "$GE" == "SLM" ]]; then
    submit_cmd=(sbatch)
fi

submit_params=()

case "$GE" in
    PBS)
        if [[ -n "$array_spec" ]]; then
            submit_params+=("-J" "$array_spec")
        fi
        if [[ -n "$wait_jobs" ]]; then
            wait_list=()
            IFS=':' read -r -a jobs <<< "$wait_jobs"
            for job in "${jobs[@]}"; do
                if job_exists "$GE" "$job"; then
                    wait_list+=("$job")
                else
                    warn "PBS dependency job not found, skipping: $job"
                fi
            done
            if (( ${#wait_list[@]} > 0 )); then
                dep='depend=afterok'
                for job in "${wait_list[@]}"; do
                    dep="${dep}:${job}"
                done
                submit_params+=("-W" "$dep")
            fi
        fi
        ;;
    SGE)
        if [[ -n "$array_spec" ]]; then
            submit_params+=("-t" "$array_spec")
        fi
        if [[ -n "$wait_jobs" ]]; then
            submit_params+=("-hold_jid" "${wait_jobs//:/,}")
        fi
        ;;
    TOR)
        if [[ -n "$array_spec" ]]; then
            submit_params+=("-t" "$array_spec")
        fi
        if [[ -n "$wait_jobs" ]]; then
            wait_list=()
            IFS=':' read -r -a jobs <<< "$wait_jobs"
            for job in "${jobs[@]}"; do
                if ! job_exists "$GE" "$job"; then
                    warn "Torque dependency job not found, skipping: $job"
                    continue
                fi

                if [[ "$job" == *"[]"* ]]; then
                    if bridge_job_id="$(submit_torque_array_bridge "$job" "$self_path" "${remaining_submit_params[@]}")"; then
                        wait_list+=("$bridge_job_id")
                    else
                        warn "Torque array dependency bridge failed for: $job"
                    fi
                else
                    wait_list+=("$job")
                fi
            done
            if (( ${#wait_list[@]} > 0 )); then
                dep='depend=afterok'
                for job in "${wait_list[@]}"; do
                    dep="${dep}:${job}"
                done
                submit_params+=("-W" "$dep")
            fi
        fi
        ;;
    SLM)
        if [[ -n "$array_spec" ]]; then
            submit_params+=("--array=${array_spec}")
        fi
        if [[ -n "$wait_jobs" ]]; then
            wait_list=()
            IFS=':' read -r -a jobs <<< "$wait_jobs"
            for job in "${jobs[@]}"; do
                if job_exists "$GE" "$job"; then
                    wait_list+=("$job")
                else
                    warn "Slurm dependency job not found, skipping: $job"
                fi
            done
            if (( ${#wait_list[@]} > 0 )); then
                dep='afterok'
                for job in "${wait_list[@]}"; do
                    dep="${dep}:${job}"
                done
                submit_params+=("--dependency=${dep}")
            fi
        fi
        ;;
esac

if (( ${#remaining_submit_params[@]} > 0 )); then
    submit_params+=("${remaining_submit_params[@]}")
fi
submit_params+=("$scriptname")

if [[ -z "$log_stem" ]]; then
    submit_log="qsub.${today_log}.log"
else
    submit_log="${log_stem}.${today_log}.log"
fi

printf -v submit_pretty '%q ' "${submit_cmd[@]}" "${submit_params[@]}"
submit_pretty="${submit_pretty% }"

if ! submit_output="$("${submit_cmd[@]}" "${submit_params[@]}" 2>&1)"; then
    {
        echo "$job_name"
        echo "QSUB_TIME: $today"
        echo "QSUB_STATUS: FAILED"
        echo "QSUB_OUT: $submit_output"
        echo "QSUB_PARAMS: $*"
        echo "QSUB_SUBMIT: $submit_pretty"
        echo "-----------------------------"
        echo ""
    } >> "$submit_log"
    printf '%s\n' "$submit_output" >&2
    exit 1
fi

job_id="$(parse_job_id "$GE" "$submit_output")"
if [[ -z "$job_id" ]]; then
    warn "Unable to parse job id from submit output"
    job_id="$submit_output"
fi

{
    echo "$job_name"
    echo "QSUB_TIME: $today"
    echo "QSUB_STATUS: OK"
    echo "QSUB_OUT: $submit_output"
    echo "QSUB_JOB_ID: $job_id"
    echo "QSUB_PARAMS: $*"
    echo "QSUB_SUBMIT: $submit_pretty"
    echo "-----------------------------"
    echo ""
} >> "$submit_log"

printf '%s\n' "$job_id"
