#!/bin/bash
#===============================================================================
# qsubsh2
# Compatible job submitter for PBS Pro, Torque, SGE and Slurm
#
# This script keeps the same calling style as qsubshcom:
# qsubsh2 "command1 |; command2" num_CPU memory task_name wait_time other_params
#
# Internal improvements:
# - submit failure is logged and returns non-zero
# - temp script cleanup uses trap
# - monitor sums CPU seconds instead of formatted cputime strings
# - small robustness fixes for quoting and array task id fallback
#===============================================================================

set -o pipefail

scriptname=$(mktemp "${TMPDIR:-/tmp}/qsubsh2.XXXXXX") || {
    echo "Error when creating temporary submit script" >&2
    exit 1
}

cleanup() {
    rm -f "$scriptname"
}
trap cleanup EXIT

if [[ $# != 6 ]]; then
    echo "Error when submitting the job, params: $*"
    exit 1
fi

if [ -z "$4" ]; then
    echo "No job name"
    exit 1
else
    name=$4
fi

self_cmd="$0"
mkdir -p ./job_reports
today=$(date +%Y.%m.%d_%H.%M.%S)
todayLOG=$(date +%Y.%m.%d)

additions="$6 ${QSUBSHCOM_EXTRAS}"

GE=$(sed -nr 's/^.*-ge=(\S*)\s?.*$/\1/p' <<< "$additions")
if [ -z "$GE" ]; then
    pbs_file=$(command -v qorder)
    if [[ -n "$pbs_file" ]]; then
        pbs_folder=$(dirname "$pbs_file")
        GE="PBS"
        if [[ -f "$pbs_folder/qchkpt" ]]; then
            GE="TOR"
        fi
    fi

    ge_file=$(command -v qsh)
    if [[ -n "$ge_file" ]]; then
        GE="SGE"
    fi

    slm_file=$(command -v sbatch)
    if [[ -n "$slm_file" ]]; then
        GE="SLM"
    fi
fi

if [ -z "$GE" ]; then
    echo "Sorry, we can't recognize the grid engine"
    echo "You can use -ge=TOR|SGE|PBS|SLM in the 6th parameter to specify"
    exit 1
fi

mem_raw="$3"
mem=$(printf "%s\n" "${mem_raw//[![:digit:]]/}")
mem_unit=$(printf "%s\n" "${mem_raw//[[:digit:]]/}")
if [ -z "$mem_unit" ]; then
    echo "Sorry, you have to specify the memory unit (3 parameter) in GB or MB or KB"
    exit 1
fi

if [ "$GE" == "TOR" ] || [ "$GE" == "SLM" ]; then
    MEM_UNIT="${mem_unit^^}"
    if [ "${MEM_UNIT: -1}" != "B" ]; then
        MEM_UNIT="${MEM_UNIT}B"
    fi
    mem_unit="$MEM_UNIT"
fi

mem_core=$(( (mem + $2 - 1) / $2 ))

ntype=$(sed -nr 's/^.*-ntype=(\S*)\s?.*$/\1/p' <<< "$additions")
if [[ -n "$ntype" ]]; then
    ntype=":NodeType=$ntype"
fi

queue=$(sed -nr 's/^.*-queue=(\S*)\s?.*$/\1/p' <<< "$additions")
account=$(sed -nr 's/^.*-acct=(\S*)\s?.*$/\1/p' <<< "$additions")

echo '#!/bin/bash' > "$scriptname"

if [ "$GE" == "SGE" ]; then
    echo "#$ -N ${name}" >> "$scriptname"
    echo "#$ -S /bin/bash" >> "$scriptname"
    echo "#$ -j y" >> "$scriptname"
    echo "#$ -o ./job_reports/" >> "$scriptname"
    echo "#$ -cwd" >> "$scriptname"
    echo "#$ -V" >> "$scriptname"
    echo "#$ -pe thread $2" >> "$scriptname"
    echo "#$ -l h_vmem=${mem_core}${mem_unit}" >> "$scriptname"
    echo 'export TASK_ID=${SGE_TASK_ID:-0}' >> "$scriptname"
fi

if [ "$GE" == "PBS" ] || [ "$GE" == "TOR" ]; then
    echo "#PBS -N ${name}" >> "$scriptname"
    echo "#PBS -S /bin/bash" >> "$scriptname"
    echo "#PBS -V" >> "$scriptname"
    echo "#PBS -l select=1:ncpus=$2${ntype}:mem=${mem}${mem_unit}" >> "$scriptname"
    if [ -n "$5" ]; then
        echo "#PBS -l walltime=$5" >> "$scriptname"
    fi
    if [[ -n "$queue" ]]; then
        echo "#PBS -q $queue" >> "$scriptname"
    fi
    if [[ -n "$account" ]]; then
        echo "#PBS -A $account" >> "$scriptname"
    fi
fi

if [ "$GE" == "SLM" ]; then
    echo "#SBATCH --job-name=${name}" >> "$scriptname"
    echo "#SBATCH --ntasks=1" >> "$scriptname"
    echo "#SBATCH --cpus-per-task=$2" >> "$scriptname"
    echo "#SBATCH --mem=${mem}${mem_unit}" >> "$scriptname"
    if [ -n "$5" ]; then
        echo "#SBATCH --time=$5" >> "$scriptname"
    fi
    if [[ -n "$queue" ]]; then
        echo "#SBATCH --partition $queue" >> "$scriptname"
    fi
    if [[ -n "$account" ]]; then
        echo "#SBATCH -A $account" >> "$scriptname"
    fi
fi

isArray=0
if [ "$GE" == "PBS" ]; then
    if [[ "$additions" =~ ^.*-array.*$ ]]; then
        echo "#PBS -o ./job_reports/${name}_${today}_A^array_index^.log" >> "$scriptname"
        echo "#PBS -e ./job_reports/${name}_${today}_A^array_index^.err" >> "$scriptname"
        isArray=1
    else
        echo "#PBS -o ./job_reports/${name}_${today}.log" >> "$scriptname"
        echo "#PBS -e ./job_reports/${name}_${today}.err" >> "$scriptname"
    fi
fi

if [ "$GE" == "TOR" ]; then
    if [[ "$additions" =~ ^.*-array.*$ ]]; then
        echo "#PBS -o ./job_reports/${name}_${today}.submit.log" >> "$scriptname"
        echo "#PBS -e ./job_reports/${name}_${today}.submit.err" >> "$scriptname"
        isArray=1
    else
        echo "#PBS -o ./job_reports/${name}_${today}.log" >> "$scriptname"
        echo "#PBS -e ./job_reports/${name}_${today}.err" >> "$scriptname"
    fi
fi

if [ "$GE" == "SLM" ]; then
    if [[ "$additions" =~ ^.*-array.*$ ]]; then
        echo "#SBATCH -o ./job_reports/${name}_${today}_A%a.log" >> "$scriptname"
        echo "#SBATCH -e ./job_reports/${name}_${today}_A%a.err" >> "$scriptname"
        isArray=1
    else
        echo "#SBATCH -o ./job_reports/${name}_${today}.log" >> "$scriptname"
        echo "#SBATCH -e ./job_reports/${name}_${today}.err" >> "$scriptname"
    fi
fi

if [ "$GE" == "PBS" ] || [ "$GE" == "TOR" ]; then
    echo 'cd "${PBS_O_WORKDIR:-$PWD}"' >> "$scriptname"
    echo 'export JOB_ID=${PBS_JOBID}' >> "$scriptname"
    echo 'export TASK_ID=${PBS_ARRAY_INDEX:-${PBS_ARRAYID:-0}}' >> "$scriptname"
fi

if [ "$GE" == "SLM" ]; then
    echo 'export JOB_ID=${SLURM_JOB_ID}' >> "$scriptname"
    echo 'export TASK_ID=${SLURM_ARRAY_TASK_ID:-0}' >> "$scriptname"
fi

if [ "$GE" == "TOR" ] && [ "$isArray" -eq 1 ]; then
    echo "exec > \"./job_reports/${name}_${today}_A\${TASK_ID}.log\" 2> \"./job_reports/${name}_${today}_A\${TASK_ID}.err\"" >> "$scriptname"
fi

echo 'echo "Job ID: ${JOB_ID}"' >> "$scriptname"
echo 'echo "Array ID: ${TASK_ID}"' >> "$scriptname"

{
    echo "cat << 'EOF'"
    echo " PARAM to here: $* "
    echo "EOF"
} >> "$scriptname"

echo 'echo ""' >> "$scriptname"
echo 'echo ========QSUB STD out========' >> "$scriptname"

if [ "$isArray" -eq 1 ]; then
    echo "mlog=\"./job_reports/${name}_${today}_A\${TASK_ID}.mon\"" >> "$scriptname"
else
    echo "mlog=\"./job_reports/${name}_${today}.mon\"" >> "$scriptname"
fi
echo "tMon=10" >> "$scriptname"

cat <<'EOF' >> "$scriptname"
collect_child_pids() {
    local parent_pid="$1"
    local child=""
    if command -v pgrep >/dev/null 2>&1; then
        while IFS= read -r child; do
            [[ -n "$child" ]] || continue
            echo "$child"
            collect_child_pids "$child"
        done < <(pgrep -P "$parent_pid" 2>/dev/null || true)
    else
        local status_file=""
        local maybe_pid=""
        local maybe_ppid=""
        for status_file in /proc/[0-9]*/status; do
            [[ -r "$status_file" ]] || continue
            maybe_pid="${status_file%/status}"
            maybe_pid="${maybe_pid##*/}"
            maybe_ppid="$(awk '/^PPid:/ { print $2; exit }' "$status_file" 2>/dev/null)"
            if [[ "$maybe_ppid" == "$parent_pid" ]]; then
                echo "$maybe_pid"
                collect_child_pids "$maybe_pid"
            fi
        done
    fi
}

read_proc_metrics() {
    local pid="$1"
    local stat_line=""
    local stat_tail=""
    local utime=0
    local stime=0
    local vsize=0
    local rss_pages=0
    local vmhwm=0

    [[ -r "/proc/$pid/stat" ]] || return 1

    stat_line="$(cat "/proc/$pid/stat" 2>/dev/null)" || return 1
    stat_tail="${stat_line#*) }"
    set -- $stat_tail

    utime="${12:-0}"
    stime="${13:-0}"
    vsize="${21:-0}"
    rss_pages="${22:-0}"

    if [[ -r "/proc/$pid/status" ]]; then
        vmhwm="$(awk '/VmHWM:/ { print $2; exit }' "/proc/$pid/status" 2>/dev/null)"
    fi

    printf '%s %s %s %s\n' \
        "$((utime + stime))" \
        "$((rss_pages * PAGE_SIZE_KB))" \
        "$((vsize / 1024))" \
        "${vmhwm:-0}"
}

sum_res_pids() {
    local runid1="$1"
    local elapsed="$2"
    local temp_file=""
    local curid1=""
    local res=""
    local pids=( "$runid1" )

    temp_file=$(mktemp)

    while IFS= read -r curid1; do
        [[ -n "$curid1" ]] && pids+=( "$curid1" )
    done < <(collect_child_pids "$runid1")

    for curid1 in "${pids[@]}"; do
        read_proc_metrics "$curid1" >> "$temp_file" 2>/dev/null || true
    done

    if [[ -s "$temp_file" ]]; then
        res=$(awk -v elapsed="$elapsed" -v clk_tck="$CLK_TCK" '
            {
                sum_ticks += $1
                sum_rss += $2
                sum_vsz += $3
                sum_vmhwm += $4
            }
            END {
                cpu_seconds = (clk_tck > 0 ? sum_ticks / clk_tck : 0)
                pcpu = (elapsed > 0 ? (cpu_seconds * 100.0 / elapsed) : 0)
                printf "%d\t%.2f\t%d\t%d\t%d", cpu_seconds, pcpu, sum_rss, sum_vsz, sum_vmhwm
            }
        ' "$temp_file")
    else
        res=$'0\t0.00\t0\t0\t0'
    fi

    rm -f "$temp_file"
    echo -e "$elapsed\t$res"
}

monitor() {
    local interval="$1"
    local logfile="$2"
    local start_epoch=0
    local now_epoch=0
    local elapsed=0
    local mid=$BASHPID
    local curid=$$
    local ppid=$PPID
    local timeNow=""
    local countChild=0
    local runct=0
    local runid=""

    echo "Task start: $(date +%T)" > "$logfile"
    echo "\$BASHPID: $mid" >> "$logfile"
    echo "\$\$: $curid" >> "$logfile"
    echo "\$PPID: $ppid" >> "$logfile"
    echo "" >> "$logfile"
    echo -e "Time\tELAPSED\tCPU_SECONDS\t%CPU\tRSS\tVSZ\tVmHWM" >> "$logfile"
    start_epoch=$(date +%s)

    while true; do
        timeNow="$(date +%T)"
        now_epoch=$(date +%s)
        elapsed=$((now_epoch - start_epoch))
        countChild=$(ps --no-headers -o pid= --ppid "$ppid" 2>/dev/null | sed '/^\s*$/d' | wc -l)
        if [ "$countChild" -eq 0 ]; then
            echo "" >> "$logfile"
            echo "Task finished: $(date +%T)" >> "$logfile"
            break
        fi

        runct=$(ps --no-headers -o pid= --ppid "$curid" 2>/dev/null | grep -vw "$mid" | sed '/^\s*$/d' | wc -l)
        if [ "$runct" -eq 1 ]; then
            runid=$(ps --no-headers -o pid= --ppid "$curid" 2>/dev/null | grep -vw "$mid" | awk 'NR==1 {print $1}')
            echo -e "$timeNow\t$(sum_res_pids "$runid" "$elapsed")" >> "$logfile"
        elif [ "$runct" -eq 0 ]; then
            echo "$timeNow: No job" >> "$logfile"
        else
            echo "$timeNow: multiple job" >> "$logfile"
            ps --no-headers -o pid=,comm= --ppid "$curid" >> "$logfile"
        fi

        sleep "$interval"
    done
}

CLK_TCK=$(getconf CLK_TCK 2>/dev/null)
if [[ -z "$CLK_TCK" || "$CLK_TCK" -le 0 ]]; then
    CLK_TCK=100
fi

PAGE_SIZE=$(getconf PAGESIZE 2>/dev/null)
if [[ -z "$PAGE_SIZE" || "$PAGE_SIZE" -le 0 ]]; then
    PAGE_SIZE=4096
fi
PAGE_SIZE_KB=$((PAGE_SIZE / 1024))
if [[ "$PAGE_SIZE_KB" -le 0 ]]; then
    PAGE_SIZE_KB=4
fi

monitor "$tMon" "$mlog" &
EOF

echo "export OMP_NUM_THREADS=$2" >> "$scriptname"
sed "s/\$\?{TASK_ID}/\${TASK_ID}/g" <<< "$1" | sed "s/\s*|;\s*/\n/g" >> "$scriptname"
echo 'echo =========QSUB STD end=========' >> "$scriptname"
echo 'echo ""' >> "$scriptname"
echo 'echo ""' >> "$scriptname"
echo 'echo ""' >> "$scriptname"
echo 'echo ""' >> "$scriptname"
echo 'echo ""' >> "$scriptname"

params=$scriptname
log=""
if [ -n "$additions" ]; then
    raw_param=$additions
    wait_jb=$(sed -nr 's/^.*-wait=(\S*)\s?.*$/\1/p' <<< "$raw_param")
    arrays=$(sed -nr 's/^.*-array=(\S*)\s?.*$/\1/p' <<< "$raw_param")
    log=$(sed -nr 's/^.*-log=(\S*)\s?.*$/\1/p' <<< "$raw_param")
    remain_param=$(echo "$raw_param" | sed 's/-ge=\S*//g' | sed 's/-log=\S*//g' | sed 's/-wait=\S*//g' | sed 's/-array=\S*//g' | sed 's/-ntype=\S*//g' | sed 's/-queue=\S*//g' | sed 's/-acct=\S*//g')

    if [ "$GE" == "PBS" ]; then
        if [[ -n "$arrays" ]]; then
            params="-J $arrays $params"
        fi
        if [[ -n "$wait_jb" ]]; then
            wait_list=""
            IFS=':' read -ra jobs <<< "$wait_jb"
            for job in "${jobs[@]}"; do
                if qstat -f "$job" >/dev/null 2>&1; then
                    wait_list="$wait_list:$job"
                fi
            done
            if [[ -n "$wait_list" ]]; then
                params="-W depend=afterok$wait_list $params"
            fi
        fi
    elif [ "$GE" == "SGE" ]; then
        if [[ -n "$arrays" ]]; then
            params="-t $arrays $params"
        fi
        if [[ -n "$wait_jb" ]]; then
            wait_jb=$(sed 's/:/,/g' <<< "$wait_jb")
            params="-hold_jid $wait_jb $params"
        fi
    elif [ "$GE" == "TOR" ]; then
        if [[ -n "$arrays" ]]; then
            params="-t $arrays $params"
        fi
        if [[ -n "$wait_jb" ]]; then
            wait_list=""
            IFS=':' read -ra jobs <<< "$wait_jb"
            for job in "${jobs[@]}"; do
                if qstat -f "$job" >/dev/null 2>&1; then
                    if [[ $job == *"[]"* ]]; then
                        job_id=$("$self_cmd" "echo torque-array-wait-bridge" 1 10MB qwait_ar 00:00:30 "-W depend=afterokarray:$job $remain_param" 2>/dev/null)
                        if [[ -n "$job_id" ]]; then
                            wait_list="$wait_list:$job_id"
                        fi
                    else
                        wait_list="$wait_list:$job"
                    fi
                fi
            done
            if [[ -n "$wait_list" ]]; then
                params="-W depend=afterok$wait_list $params"
            fi
        fi
    elif [ "$GE" == "SLM" ]; then
        if [[ -n "$arrays" ]]; then
            params="--array=$arrays $params"
        fi
        if [[ -n "$wait_jb" ]]; then
            wait_list=""
            IFS=':' read -ra jobs <<< "$wait_jb"
            for job in "${jobs[@]}"; do
                if squeue -h -j "$job" 2>/dev/null | grep -q .; then
                    wait_list="$wait_list:$job"
                fi
            done
            if [[ -n "$wait_list" ]]; then
                params="--dependency=afterok$wait_list $params"
            fi
        fi
    fi
    params="$remain_param $params"
fi

submit_pretty=""
if [ "$GE" == "SLM" ]; then
    submit_pretty="sbatch $params"
else
    submit_pretty="qsub $params"
fi

if [ -z "$log" ]; then
    log="qsub.$todayLOG.log"
else
    log="$log.$todayLOG.log"
fi

{
    echo "$name"
    echo "QSUB_TIME: $today"
    echo "QSUB_PARAMS: $*"
    echo "QSUB_SUBMIT: $submit_pretty"
} >> "$log"

if [ "$GE" == "SLM" ]; then
    output=$(sbatch $params 2>&1)
    submit_status=$?
else
    output=$(qsub $params 2>&1)
    submit_status=$?
fi

echo "QSUB_OUT: $output" >> "$log"

if [ "$submit_status" -ne 0 ]; then
    echo "QSUB_STATUS: FAILED" >> "$log"
    echo "-----------------------------" >> "$log"
    echo " " >> "$log"
    echo "$output" >&2
    exit "$submit_status"
fi

echo "QSUB_STATUS: OK" >> "$log"
printf "QSUB_JOB_ID: " >> "$log"

if [ "$GE" == "SGE" ]; then
    job_id=$(echo "$output" | sed -r 's/Your (job|job-array) ([0-9]*).*/\2/')
    echo "$job_id"
    echo "$job_id" >> "$log"
fi

if [ "$GE" == "PBS" ]; then
    job_id="$output"
    echo "$job_id"
    echo "$job_id" >> "$log"
fi

if [ "$GE" == "TOR" ]; then
    job_id=$(echo "$output" | tail -n 1 | tr -d '\n')
    echo "$job_id"
    echo "$job_id" >> "$log"
fi

if [ "$GE" == "SLM" ]; then
    job_id=$(echo "$output" | sed -r 's/.* ([0-9]*).*/\1/g')
    echo "$job_id"
    echo "$job_id" >> "$log"
fi

echo "-----------------------------" >> "$log"
echo " " >> "$log"
